{
  "name": "socialcalc",
  "version": "3.0.8",
  "description": "Collaborative spreadsheet editor",
  "keywords": [
    "calc",
    "cells",
    "editor",
    "ethercalc",
    "excel",
    "grid",
    "office",
    "socialcalc",
    "spreadsheet",
    "spreadsheets",
    "table"
  ],
  "homepage": "https://github.com/audreyt/socialcalc#readme",
  "bugs": {
    "url": "https://github.com/audreyt/socialcalc/issues"
  },
  "license": "(CPAL-1.0 AND Artistic-2.0 AND MPL-2.0)",
  "author": "Dan Bricklin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audreyt/socialcalc.git"
  },
  "files": [
    "dist/SocialCalc.js",
    "dist/SocialCalc.d.ts",
    "dist/socialcalc.css",
    "js/*.d.ts",
    "css/socialcalc.css",
    "LICENSE.txt",
    "LEGAL.txt",
    "README.md"
  ],
  "main": "dist/SocialCalc.js",
  "types": "dist/SocialCalc.d.ts",
  "scripts": {
    "build": "bun run build.ts",
    "build:min": "bun run build.ts --minify",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc --noEmit -p tsconfig.strict.json",
    "test": "bun run build.ts && vp test",
    "test:coverage": "bun run build.ts && vp test --coverage",
    "mutate": "bunx stryker run",
    "mutate:file": "bun run stryker-file.mjs",
    "mutate:format": "bun run stryker-file.mjs js/formatnumber2.ts",
    "mutate:sheet": "bun run stryker-file.mjs js/socialcalc-3.ts",
    "mutate:formula": "bun run stryker-file.mjs js/formula1.ts",
    "verify": "lsc check --backend=dafny",
    "verify:dafny": "lsc check --backend=dafny",
    "verify:dafny:gen": "lsc gen --backend=dafny",
    "verify:dafny:regen": "lsc regen --backend=dafny lemma/a1.ts && lsc regen --backend=dafny lemma/eval-ops.ts && lsc regen --backend=dafny lemma/lookup-result.ts",
    "verify:lean:gen": "lsc gen --backend=lean lemma/a1.ts && lsc gen --backend=lean lemma/eval-ops.ts && lsc gen --backend=lean lemma/lookup-result.ts",
    "verify:lean": "bun run verify:lean:gen && test -s lemma/a1.types.lean && test -s lemma/a1.def.lean && test -s lemma/a1.proof.lean && test -s lemma/eval-ops.types.lean && test -s lemma/eval-ops.def.lean && test -s lemma/eval-ops.proof.lean && test -s lemma/lookup-result.types.lean && test -s lemma/lookup-result.def.lean && test -s lemma/lookup-result.proof.lean",
    "verify:lean:build": "lake build",
    "verify:both": "bun run verify:dafny && bun run verify:lean"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "4.1.10",
    "lemmascript": "0.5.13",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  }
}
