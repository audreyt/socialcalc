function validateSheetName(isEmpty: bool, exceedsMaxLength: bool, hasInvalidChar: bool, isDuplicate: bool): int
{
  if isEmpty then
    NAME_EMPTY
  else
    if exceedsMaxLength then
      NAME_TOO_LONG
    else
      if hasInvalidChar then
        NAME_INVALID_CHARS
      else
        if isDuplicate then
          NAME_DUPLICATE
        else
          NAME_OK
}

