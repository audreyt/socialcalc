function classifyReferenceRewrite(referencesAffectedSheet: bool, isDelete: bool): int
{
  if !(referencesAffectedSheet) then
    REF_UNCHANGED
  else
    if isDelete then
      REF_BROKEN
    else
      REF_RENAMED
}

