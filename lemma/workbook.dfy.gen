function clampIndex(index: int, count: int): int
{
  if (count <= 0) then
    NO_INDEX
  else
    if (index < 0) then
      0
    else
      if (index >= count) then
        (count - 1)
      else
        index
}

lemma clampIndex_ensures(index: int, count: int)
  ensures ((count <= 0) ==> (clampIndex(index, count) == -1))
  ensures ((count > 0) ==> (index < 0) ==> (clampIndex(index, count) == 0))
  ensures ((count > 0) ==> (index >= count) ==> (clampIndex(index, count) == (count - 1)))
  ensures ((count > 0) ==> (index >= 0) ==> (index < count) ==> (clampIndex(index, count) == index))
{
}

function activeIndexAfterDelete(deletedIndex: int, activeIndex: int, oldCount: int): int
{
  if (oldCount <= 1) then
    NO_INDEX
  else
    var newCount := (oldCount - 1);
    if (deletedIndex < activeIndex) then
      clampIndex((activeIndex - 1), newCount)
    else
      clampIndex(activeIndex, newCount)
}

lemma activeIndexAfterDelete_ensures(deletedIndex: int, activeIndex: int, oldCount: int)
  ensures ((oldCount <= 1) ==> (activeIndexAfterDelete(deletedIndex, activeIndex, oldCount) == -1))
